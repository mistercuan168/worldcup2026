# Copy this file to ".env" and fill in your free API keys.
# The .env file is gitignored and must never be committed.
#
# Both keys are OPTIONAL. The model trains fine on the historical results CSV alone.
# You only need these to pull live World Cup 2026 fixtures and results.

# football-data.org  — free tier, 10 requests/minute. Sign up: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# API-Football (api-sports.io) — free tier, 100 requests/day. Sign up: https://dashboard.api-football.com/register
API_FOOTBALL_KEY=
